{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connector Source Documentation",
  "type": "object",
  "required": ["datasource", "confirmed_docs"],
  "properties": {
    "datasource": { "type": "string" },
    "confirmed_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title", "source_type", "confirmed_by_user"],
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": ["official", "internal", "example", "community", "unknown"]
          },
          "summary": { "type": "string" },
          "confirmed_by_user": { "type": "boolean" }
        }
      }
    },
    "rejected_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "reason"],
        "properties": {
          "url": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
