# Generated by glean-deploy init --cloud gcp
# DO NOT EDIT THIS FILE MANUALLY — re-run glean-deploy init to regenerate.
#
# References:
#   Terraform:              https://developer.hashicorp.com/terraform/docs
#   GCP Provider:           https://registry.terraform.io/providers/hashicorp/google/latest/docs
#   GKE CronJob:            https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/
#   GCP Secret Manager:     https://cloud.google.com/secret-manager/docs
#   GCP Workload Identity:  https://cloud.google.com/kubernetes-engine/docs/how-to/workload-identity
#   GCP Cloud Monitoring:   https://cloud.google.com/monitoring/docs

terraform {
  required_version = ">= 1.0"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 4.0"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = ">= 2.0"
    }
  }
}

provider "google" {
  project = var.project_id
  region  = var.region
}

data "google_client_config" "default" {}

data "google_container_cluster" "main" {
  name     = var.cluster_name
  location = var.region
}

provider "kubernetes" {
  host                   = "https://${data.google_container_cluster.main.endpoint}"
  token                  = data.google_client_config.default.access_token
  cluster_ca_certificate = base64decode(data.google_container_cluster.main.master_auth[0].cluster_ca_certificate)
}

# ----- Service Account -----
# Least-privilege IAM for the connector pod.
# Reference: https://cloud.google.com/kubernetes-engine/docs/how-to/workload-identity

resource "google_service_account" "connector" {
  account_id   = "{{ config.effective_service_account }}"
  display_name = "Glean connector: {{ config.connector_name }}"
  project      = var.project_id
}

# Allow the connector to list secrets by prefix.
# Reference: https://cloud.google.com/secret-manager/docs/access-control
resource "google_project_iam_member" "secret_viewer" {
  project = var.project_id
  role    = "roles/secretmanager.viewer"
  member  = "serviceAccount:${google_service_account.connector.email}"
}

# Allow writing structured logs.
# Reference: https://cloud.google.com/logging/docs/access-control
resource "google_project_iam_member" "log_writer" {
  project = var.project_id
  role    = "roles/logging.logWriter"
  member  = "serviceAccount:${google_service_account.connector.email}"
}

# Allow emitting custom metrics.
# Reference: https://cloud.google.com/monitoring/docs/access-control
resource "google_project_iam_member" "metric_writer" {
  project = var.project_id
  role    = "roles/monitoring.metricWriter"
  member  = "serviceAccount:${google_service_account.connector.email}"
}

# Bind GCP service account to Kubernetes service account via Workload Identity.
# Reference: https://cloud.google.com/kubernetes-engine/docs/how-to/workload-identity
resource "google_service_account_iam_member" "workload_identity" {
  service_account_id = google_service_account.connector.name
  role               = "roles/iam.workloadIdentityUser"
  member             = "serviceAccount:${var.project_id}.svc.id.goog[${var.namespace}/{{ config.k8s_name }}-ksa]"
}

# Allow accessing secret values at runtime.
# Reference: https://cloud.google.com/secret-manager/docs/access-control
resource "google_project_iam_member" "secret_accessor" {
  project = var.project_id
  role    = "roles/secretmanager.secretAccessor"
  member  = "serviceAccount:${google_service_account.connector.email}"
}

resource "kubernetes_service_account_v1" "connector" {
  metadata {
    name      = "{{ config.k8s_name }}-ksa"
    namespace = var.namespace
    annotations = {
      "iam.gke.io/gcp-service-account" = google_service_account.connector.email
    }
  }
}

# ----- CronJob -----
# Reference: https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/

resource "kubernetes_cron_job_v1" "connector" {
  metadata {
    name      = "{{ config.k8s_name }}"
    namespace = var.namespace
    labels = {
      app        = "{{ config.k8s_name }}"
      managed-by = "glean-deploy"
    }
  }

  spec {
    schedule                      = "{{ config.cron_schedule }}"
    concurrency_policy            = "Forbid"
    failed_jobs_history_limit     = 3
    successful_jobs_history_limit = 3

    job_template {
      metadata {
        labels = {
          app = "{{ config.k8s_name }}"
        }
      }
      spec {
        backoff_limit = 1
        template {
          metadata {
            labels = {
              app = "{{ config.k8s_name }}"
            }
          }
          spec {
            service_account_name = kubernetes_service_account_v1.connector.metadata[0].name
            restart_policy       = "Never"

            container {
              name  = "{{ config.k8s_name }}"
              image = var.image

              # Deployment-control env vars — NOT loaded from secret manager.
              env {
                name  = "DATASOURCE_NAME"
                value = "{{ config.connector_name }}"
              }
              env {
                name  = "CLOUD_PLATFORM"
                value = "gcp"
              }
              env {
                name  = "INDEXING_MODE"
                value = "{{ config.indexing_mode }}"
              }
              env {
                name  = "GOOGLE_CLOUD_PROJECT"
                value = var.project_id
              }
              env {
                name  = "CONNECTOR_CLASS"
                value = "{{ config.connector_class }}"
              }
              env {
                name  = "CONNECTOR_MODULE"
                value = "{{ config.connector_module }}"
              }

              resources {
                requests = {
                  cpu    = "{{ config.cpu }}"
                  memory = "{{ config.memory }}"
                }
                limits = {
                  cpu    = "{{ config.cpu }}"
                  memory = "{{ config.memory }}"
                }
              }

              # No privileged mode, no extra capabilities.
              security_context {
                allow_privilege_escalation = false
                run_as_non_root            = true
              }
            }
          }
        }
      }
    }
  }
}
