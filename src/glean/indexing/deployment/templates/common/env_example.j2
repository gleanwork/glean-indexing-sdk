# .env.example — connector secrets template
# Generated by: glean-deploy init --cloud {{ config.cloud }}
#
# Copy this file to .env and fill in your connector credentials.
# Then run: glean-deploy secrets upload
#
# HOW SECRETS WORK:
#   - Variables in this file (except the DEPLOYMENT CONTROL section below) are
#     uploaded to {{ 'GCP Secret Manager' if config.cloud == 'gcp' else 'AWS Secrets Manager' }}
#     under the prefix: CUSTOM_DATASOURCE_PLATFORM_{{ config.connector_name | upper }}_
#   - At runtime, run.py reads them back and sets them as env vars before
#     starting the connector.
#
# References:
{% if config.cloud == 'gcp' %}
#   GCP Secret Manager: https://cloud.google.com/secret-manager/docs
{% else %}
#   AWS Secrets Manager: https://docs.aws.amazon.com/secretsmanager/latest/userguide/intro.html
{% endif %}
#   Glean Indexing API:  https://developers.glean.com/indexing/api

# ============================================================
# DEPLOYMENT CONTROL (never uploaded to secret manager)
# These are set automatically by Terraform in the CronJob spec.
# ============================================================
DATASOURCE_NAME={{ config.connector_name }}
CLOUD_PLATFORM={{ config.cloud }}
INDEXING_MODE={{ config.indexing_mode }}
{% if config.cloud == 'gcp' %}
GOOGLE_CLOUD_PROJECT={{ config.project_id }}  # https://cloud.google.com/resource-manager/docs/creating-managing-projects
{% else %}
AWS_REGION={{ config.region }}
{% endif %}

# ============================================================
# GLEAN API CREDENTIALS (uploaded to secret manager)
# ============================================================
GLEAN_SERVER_URL=https://<your-instance>-be.glean.com  # Your Glean backend URL
GLEAN_INDEXING_API_TOKEN=your-glean-api-token-here      # https://developers.glean.com/indexing/api#authentication

# ============================================================
# CONNECTOR SECRETS (uploaded to secret manager)
# Add your connector-specific credentials below.
# ============================================================
# Example: MY_API_KEY=your-api-key-here
# Example: MY_DATABASE_PASSWORD=your-password-here
