# Generated by glean-deploy init --cloud aws
# DO NOT EDIT THIS FILE MANUALLY — re-run glean-deploy init to regenerate.
#
# References:
#   Terraform:             https://developer.hashicorp.com/terraform/docs
#   AWS Provider:          https://registry.terraform.io/providers/hashicorp/aws/latest/docs
#   EKS CronJob:           https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/
#   AWS Secrets Manager:   https://docs.aws.amazon.com/secretsmanager/latest/userguide/intro.html
#   AWS IRSA:              https://docs.aws.amazon.com/eks/latest/userguide/iam-roles-for-service-accounts.html
#   AWS CloudWatch:        https://docs.aws.amazon.com/AmazonCloudWatch/latest/monitoring/WhatIsCloudWatch.html

terraform {
  required_version = ">= 1.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 4.0"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = ">= 2.0"
    }
  }
}

provider "aws" {
  region = var.region
}

data "aws_eks_cluster" "main" {
  name = var.cluster_name
}

data "aws_eks_cluster_auth" "main" {
  name = var.cluster_name
}

provider "kubernetes" {
  host                   = data.aws_eks_cluster.main.endpoint
  token                  = data.aws_eks_cluster_auth.main.token
  cluster_ca_certificate = base64decode(data.aws_eks_cluster.main.certificate_authority[0].data)
}

# ----- IAM Role (IRSA) -----
# Least-privilege IAM role for the connector pod.
# Reference: https://docs.aws.amazon.com/eks/latest/userguide/iam-roles-for-service-accounts.html

data "aws_iam_openid_connect_provider" "eks" {
  url = data.aws_eks_cluster.main.identity[0].oidc[0].issuer
}

resource "aws_iam_role" "connector" {
  name = "{{ config.effective_service_account }}"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Principal = {
        Federated = data.aws_iam_openid_connect_provider.eks.arn
      }
      Action = "sts:AssumeRoleWithWebIdentity"
      Condition = {
        StringEquals = {
          "${data.aws_iam_openid_connect_provider.eks.url}:sub" = "system:serviceaccount:${var.namespace}:{{ config.connector_name }}-ksa"
        }
      }
    }]
  })
}

# Allow reading connector secrets by prefix.
# Reference: https://docs.aws.amazon.com/secretsmanager/latest/userguide/auth-and-access.html
resource "aws_iam_role_policy" "secrets" {
  name = "{{ config.connector_name }}-secrets"
  role = aws_iam_role.connector.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = ["secretsmanager:ListSecrets"]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
        Resource = "arn:aws:secretsmanager:${var.region}:${var.account_id}:secret:CUSTOM_DATASOURCE_PLATFORM_{{ config.connector_name | upper }}_*"
      }
    ]
  })
}

# Allow writing logs and metrics to CloudWatch.
# Reference: https://docs.aws.amazon.com/AmazonCloudWatch/latest/monitoring/WhatIsCloudWatch.html
resource "aws_iam_role_policy" "cloudwatch" {
  name = "{{ config.connector_name }}-cloudwatch"
  role = aws_iam_role.connector.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ]
        Resource = "arn:aws:logs:${var.region}:${var.account_id}:log-group:/glean/connectors/{{ config.connector_name }}:*"
      },
      {
        Effect   = "Allow"
        Action   = ["cloudwatch:PutMetricData"]
        Resource = "*"
        Condition = {
          StringEquals = {
            "cloudwatch:namespace" = "GleanConnectors"
          }
        }
      }
    ]
  })
}

resource "kubernetes_service_account" "connector" {
  metadata {
    name      = "{{ config.connector_name }}-ksa"
    namespace = var.namespace
    annotations = {
      "eks.amazonaws.com/role-arn" = aws_iam_role.connector.arn
    }
  }
}

# ----- CronJob -----
# Reference: https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/

resource "kubernetes_cron_job_v1" "connector" {
  metadata {
    name      = "{{ config.connector_name }}"
    namespace = var.namespace
    labels = {
      app        = "{{ config.connector_name }}"
      managed-by = "glean-deploy"
    }
  }

  spec {
    schedule                      = "{{ config.cron_schedule }}"
    concurrency_policy            = "Forbid"
    failed_jobs_history_limit     = 3
    successful_jobs_history_limit = 3

    job_template {
      metadata {}
      spec {
        backoff_limit = 1
        template {
          metadata {}
          spec {
            service_account_name = kubernetes_service_account.connector.metadata[0].name
            restart_policy       = "Never"

            container {
              name  = "{{ config.connector_name }}"
              image = var.image

              # Deployment-control env vars — NOT loaded from secret manager.
              env {
                name  = "DATASOURCE_NAME"
                value = "{{ config.connector_name }}"
              }
              env {
                name  = "CLOUD_PLATFORM"
                value = "aws"
              }
              env {
                name  = "INDEXING_MODE"
                value = "{{ config.indexing_mode }}"
              }
              env {
                name  = "AWS_REGION"
                value = var.region
              }
              env {
                name  = "CONNECTOR_CLASS"
                value = "{{ config.connector_class }}"
              }
              env {
                name  = "CONNECTOR_MODULE"
                value = "{{ config.connector_module }}"
              }

              resources {
                requests = {
                  cpu    = "{{ config.cpu }}"
                  memory = "{{ config.memory }}"
                }
                limits = {
                  cpu    = "{{ config.cpu }}"
                  memory = "{{ config.memory }}"
                }
              }

              security_context {
                allow_privilege_escalation = false
                run_as_non_root            = true
              }
            }
          }
        }
      }
    }
  }
}
