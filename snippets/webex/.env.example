# Webex source API token. For the first prototype this is a personal access token,
# so it only sees content visible to that Webex user.
WEBEX_ACCESS_TOKEN=

# Optional local safety cap while testing.
WEBEX_MAX_ROOMS=10

# Glean Indexing SDK credentials.
GLEAN_SERVER_URL=https://<instance>.glean.com
GLEAN_INDEXING_API_TOKEN=

# full or incremental. Incremental currently depends on the SDK runner's crawl timestamp.
GLEAN_INDEXING_MODE=full
