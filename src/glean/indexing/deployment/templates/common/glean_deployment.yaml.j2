# glean_deployment.yaml — connector deployment configuration
# Generated by: glean-deploy init --cloud {{ config.cloud }}
# Edit this file to adjust your deployment, then run:
#   glean-deploy build --push
#   glean-deploy secrets upload
#   glean-deploy apply
#
# References:
#   Kubernetes CronJobs:  https://kubernetes.io/docs/concepts/workloads/controllers/cron-jobs/
#   Terraform:            https://developer.hashicorp.com/terraform/docs
{% if config.cloud == 'gcp' %}
#   GCP GKE:              https://cloud.google.com/kubernetes-engine/docs
#   GCP Artifact Registry: https://cloud.google.com/artifact-registry/docs
#   GCP Secret Manager:   https://cloud.google.com/secret-manager/docs
{% else %}
#   AWS EKS:              https://docs.aws.amazon.com/eks/latest/userguide/what-is-eks.html
#   AWS ECR:              https://docs.aws.amazon.com/AmazonECR/latest/userguide/what-is-ecr.html
#   AWS Secrets Manager:  https://docs.aws.amazon.com/secretsmanager/latest/userguide/intro.html
{% endif %}

connector_name: {{ config.connector_name }}
connector_class: {{ config.connector_class }}
connector_module: {{ config.connector_module }}

cloud: {{ config.cloud }}
region: {{ config.region }}
cluster_name: {{ config.cluster_name }}
namespace: {{ config.namespace }}

cpu: {{ config.cpu }}
memory: {{ config.memory }}
cron_schedule: "{{ config.cron_schedule }}"
indexing_mode: {{ config.indexing_mode }}

{% if config.cloud == 'gcp' %}
project_id: {{ config.project_id }}
artifact_registry_repo: {{ config.artifact_registry_repo }}
{% if config.service_account_name %}
service_account_name: {{ config.service_account_name }}
{% endif %}
{% else %}
account_id: {{ config.account_id }}
ecr_repo: {{ config.ecr_repo }}
{% if config.iam_role_name %}
iam_role_name: {{ config.iam_role_name }}
{% endif %}
{% endif %}
