# Webex auth option 1: Personal Access Token (simplest for MVP testing)
# Get from https://developer.webex.com/docs/getting-your-personal-access-token
WEBEX_ACCESS_TOKEN=

# Webex auth option 2: OAuth refresh-token flow
# If these three are set, the connector uses OAuth and refreshes access tokens on demand.
# WEBEX_CLIENT_ID=
# WEBEX_CLIENT_SECRET=
# WEBEX_REFRESH_TOKEN=
# Optional initial access token for OAuth mode; reused until expired.
# WEBEX_ACCESS_TOKEN=

# Glean indexing API target
# Prefer GLEAN_SERVER_URL for new configs. GLEAN_INSTANCE is still supported by the SDK.
GLEAN_SERVER_URL=https://salessavvy-test-be.glean.com
# GLEAN_INSTANCE=salessavvy-test
GLEAN_INDEXING_API_TOKEN=

# Datasource settings for the snippet
WEBEX_DATASOURCE_NAME=webex_mvp
WEBEX_INDEXING_MODE=full

# Local file checkpoint for incremental crawls.
# The connector writes {"last_activity_cursor": "..."} after a successful push.
WEBEX_CHECKPOINT_PATH=.webex/state/last_activity_cursor.json

# Fallback cursor when WEBEX_CHECKPOINT_PATH is not set.
# WEBEX_LAST_ACTIVITY_CURSOR=2026-05-18T00:00:00Z
